# =============================================================================
# Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env_template .env
#
# .env is gitignored -- your secrets stay local.
# These are loaded automatically by train.py, evaluate.py, and infer.py.
# Real environment variables take precedence over .env values.
# =============================================================================

# --- Weights & Biases ---
# Get your key at: https://wandb.ai/authorize
WANDB_API_KEY=
WANDB_ENTITY=

# --- HuggingFace Hub ---
# Create a token at: https://huggingface.co/settings/tokens
# Needs "write" permission if pushing checkpoints.
HF_TOKEN=

# --- Anthropic (for LLM-as-judge in evaluate.py) ---
# Get your key at: https://console.anthropic.com/settings/keys
# Only needed if you use --llm_judge flag.
ANTHROPIC_API_KEY=

# --- HuggingFace Hub Repo ---
# Used by cloud/teardown.sh to push checkpoints.
# Format: username/repo-name
HUB_REPO=
